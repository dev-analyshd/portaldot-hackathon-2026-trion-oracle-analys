# TRION Behavioral Oracle — PortalDot Environment Variables
# Copy to .env and fill in values before running

# ── TRION Oracle API ──────────────────────────────────────────────────────────
ORACLE_API_URL=http://127.0.0.1:5000

# ── PortalDot Node ────────────────────────────────────────────────────────────
PORTALDOT_RPC_URL=wss://rpc.portaldot.io

# ── Ink! Contract Addresses (set after deployment) ────────────────────────────
TRION_SIGNAL_GATE_ADDRESS=
BTCP_ESCROW_ADDRESS=
BLO_CONTRACT_ADDRESS=

# ── Relayer Keys ──────────────────────────────────────────────────────────────
# SR25519 mnemonic — pays POT gas for signal submissions
DOT_MNEMONIC=

# ── Oracle Bridge Settings ────────────────────────────────────────────────────
# Entities to monitor (comma-separated names or 0x addresses)
MONITORED_ENTITIES=uniswap,aave,compound,curve,lido,0xb819c63c02Ed5aB49017C0f3f2568A14624658b3

# Poll interval in milliseconds (default 60s)
POLL_INTERVAL_MS=60000

# Signal TTL in blocks (signals expire after this many PortalDot blocks)
SIGNAL_TTL_BLOCKS=500

# ── Rust log level ────────────────────────────────────────────────────────────
RUST_LOG=info
